{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananke.local/contracts/renderer-public-grill-answer-record.schema.json",
  "title": "GrillAnswerRecord",
  "description": "Public immutable acknowledgement record returned by record_grill_answer. The acknowledgement is fixed; callers cannot submit answer prose.",
  "type": "object",
  "additionalProperties": false,
  "required": ["proposal_id", "revision", "revision_hash", "question_id", "record_sequence", "answer", "written_at", "written_by"],
  "properties": {
    "proposal_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
    "revision": { "type": "integer", "minimum": 1 },
    "revision_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "question_id": { "type": "string", "pattern": "^grill_question_(observable_outcome|scope_compatibility|acceptance_evidence|destructive_external_authorization|adapter_worktree_isolation|autonomy_budget)$" },
    "record_sequence": { "type": "integer", "minimum": 1, "maximum": 40 },
    "answer": { "const": "acknowledged" },
    "written_at": { "type": "string", "x-ananke-utc-timestamp": true },
    "written_by": { "const": "local_gui_operator" }
  }
}
