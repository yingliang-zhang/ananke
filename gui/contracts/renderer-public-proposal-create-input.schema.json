{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananke.local/contracts/renderer-public-proposal-create-input.schema.json",
  "title": "CreateProposalInput",
  "description": "Public arguments of the Tauri create_proposal command.",
  "type": "object",
  "additionalProperties": false,
  "required": ["idempotency_key", "project_id", "workstream_id", "revision_input"],
  "properties": {
    "idempotency_key": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,127}$" },
    "project_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
    "workstream_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
    "revision_input": {
      "title": "CreateProposalRevisionInput",
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "acceptance_criteria", "policy"],
      "properties": {
        "task": {
          "title": "CreateProposalTask",
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "instructions"],
          "properties": {
            "title": { "type": "string", "minLength": 1, "maxLength": 160, "x-ananke-max-utf8-bytes": 160 },
            "instructions": { "type": "string", "minLength": 1, "maxLength": 8000, "x-ananke-max-utf8-bytes": 8000 }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000, "x-ananke-max-utf8-bytes": 1000 }
        },
        "policy": {
          "title": "CreateProposalPolicy",
          "type": "object",
          "additionalProperties": false,
          "required": ["adapter", "authority", "budget", "model_role"],
          "properties": {
            "adapter": {
              "title": "CreateProposalAdapterPolicy",
              "type": "object",
              "additionalProperties": false,
              "required": ["access", "kind", "status"],
              "properties": {
                "access": { "const": "read_only" },
                "kind": { "const": "omp_audit" },
                "status": { "const": "future" }
              }
            },
            "authority": { "const": "deterministic" },
            "budget": {
              "title": "CreateProposalBudgetPolicy",
              "type": "object",
              "additionalProperties": false,
              "required": ["dimensions", "status"],
              "properties": {
                "dimensions": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": { "type": "string" },
                  "prefixItems": [{ "const": "deadline" }, { "const": "attempt_cap" }]
                },
                "status": { "const": "future" }
              }
            },
            "model_role": { "const": "advisory_only" }
          }
        }
      }
    }
  }
}
