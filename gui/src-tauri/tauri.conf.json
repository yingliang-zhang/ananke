{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ananke",
  "version": "0.1.0",
  "identifier": "com.yingliangzhang.ananke",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ananke",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../.ananke/bin/ananke": "ananke-bin/ananke",
      "../../.ananke/bin/ananke-supervisor": "ananke-bin/ananke-supervisor",
      "../../.ananke/bin/ananke-fakeworker": "ananke-bin/ananke-fakeworker"
    }
  }
}
